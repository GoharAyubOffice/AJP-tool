# JobAutoApply Environment Configuration
# Copy this file to .env and fill in your API keys

# Reed API Key (get from https://www.reed.co.uk/developers/jobseeker)
REED_API_KEY=

# Anthropic API Key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Claude model to use (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Path to Master CV JSON (default: ~/.jobtool/master-cv.json)
MASTER_CV_PATH=~/.jobtool/master-cv.json

# Data directory (default: ~/.jobtool)
DATA_DIR=~/.jobtool
